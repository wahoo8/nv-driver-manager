#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

LIB_DIR="${NDM_LIB_DIR:-/usr/libexec/nvidia-driver-manager}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEV_LIB_DIR=""

if [[ -d "$SCRIPT_DIR/../lib" ]]; then
    DEV_LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"
fi

if [[ -n "$DEV_LIB_DIR" && -f "$DEV_LIB_DIR/bootstrap.sh" ]]; then
    LIB_DIR="$DEV_LIB_DIR"
fi

# shellcheck disable=SC1091
source "$LIB_DIR/bootstrap.sh"

ndm_bootstrap

# shellcheck disable=SC1091
source "$NDM_LIB_DIR/cache.sh"

ndm_cache_init

NDM_COMMAND_DIR="${NDM_COMMAND_DIR:-$NDM_LIB_DIR/commands}"

if [[ -d "$SCRIPT_DIR/../commands" ]]; then
    NDM_COMMAND_DIR="$(cd "$SCRIPT_DIR/../commands" && pwd)"
fi

show_help()
{
    cat <<EOF
NVIDIA Driver Manager

Usage:
  nvidia-driver-manager <command>

Commands:
  check              Check for NVIDIA driver updates
  download           Download latest NVIDIA driver
  install            Install downloaded NVIDIA driver
  health             Run health checks
  diagnose           Generate diagnostic report
  report             Show last installation report
  installed-version  Show installed NVIDIA driver version
  version            Show program version
  help               Show this help
EOF
}

run_command()
{
    local command="$1"
    local command_file="$NDM_COMMAND_DIR/${command}.sh"

    if [[ ! -r "$command_file" ]]; then
        ndm_fatal "Command not implemented yet: $command"
    fi

    shift
    # shellcheck disable=SC1090
    source "$command_file"
}

case "${1:-help}" in
    help|--help|-h)
        show_help
        ;;
    version|--version|-v)
        printf '%s %s\n' "$NDM_NAME" "$NDM_VERSION"
        ;;
    check|download|install|health|diagnose|report|installed-version)
        command="$1"
        shift
        run_command "$command" "$@"
        ;;
    *)
        ndm_fatal "Unknown command: $1"
        ;;
esac
